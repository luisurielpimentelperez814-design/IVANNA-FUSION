<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Control de Efectos IVANNA-FUSION"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnToggleEffect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Activar Efecto"
        android:textSize="16sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ganancia"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/textGainValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ganancia: 0dB"
        android:textSize="14sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="8dp"/>

    <SeekBar
        android:id="@+id/seekGain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnApplyEffect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aplicar Efecto"
        android:textSize="16sp"/>

</LinearLayout>

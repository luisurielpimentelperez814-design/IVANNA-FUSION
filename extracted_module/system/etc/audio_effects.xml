<?xml version="1.0" encoding="UTF-8"?>
<audio_effects_conf version="2.0" xmlns="http://schemas.android.com/audio/audio_effects_conf/v2_0">
    <libraries>
        <library name="omega_engine" path="libomega_effect.so"/>
    </libraries>
    <effects>
        <!-- UUID corregido: debe coincidir EXACTAMENTE con kEffectUuid en
             omega_effect.cpp (8d7d5e0a-a6eb-4fde-a0ff-cb1b2dd7275e). El
             UUID anterior (a1b2c3d4-...) era un placeholder que no
             coincidía con ningún UUID real compilado en la librería ->
             EffectCreate() devolvía -ENOENT y audioserver fallaba al
             instanciar el efecto en cuanto sonaba música. -->
        <effect name="omega_in_processor" library="omega_engine" uuid="8d7d5e0a-a6eb-4fde-a0ff-cb1b2dd7275e"/>
    </effects>
    <preprocess>
        <stream type="music">
            <apply effect="omega_in_processor"/>
        </stream>
    </preprocess>
</audio_effects_conf>
